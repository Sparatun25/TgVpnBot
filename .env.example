# Telegram Bot
BOT_TOKEN=                 # Токен Telegram бота от @BotFather (обязательный)
BOT_ADMIN_IDS=             # ID администраторов через запятую, например: 123456789,987654321

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/onyxvpn

# Telegram WebApp URL
WEBAPP_URL=https://onyxvpn.app

# Amnezia VPN: публичный IP сервера и имя контейнера AmneziaWG.
# Работаем через docker exec в контейнер, а не через HTTP API.
AMNEZIA_SERVER_HOST=127.0.0.1
AMNEZIA_CONTAINER_NAME=amnezia-awg2

# Payment (ЮKassa СБП)
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=

# Trial period (дни). Используется в api/routes.py:activate_trial
TRIAL_DAYS=3

# Пороги уведомлений (часов до окончания подписки).
# Используются в bot/services/scheduler.py для пушей "за 24ч" и "за 1ч".
NOTIFICATION_24H_BEFORE=24
NOTIFICATION_1H_BEFORE=1

# Admin session: TTL сессии админ-панели в секундах (по умолчанию 24 часа).
ADMIN_SESSION_TTL_SECONDS=86400
